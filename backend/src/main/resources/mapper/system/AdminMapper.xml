<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vibemyself.mapper.system.AdminMapper">

    <resultMap id="adminResultMap" type="com.vibemyself.entity.StAdminBase">
        <id property="loginId" column="LOGIN_ID"/>
        <result property="loginPwd" column="LOGIN_PWD"/>
        <result property="adminNm" column="ADMIN_NM"/>
        <result property="roleCd" column="ROLE_CD"/>
        <result property="useYn" column="USE_YN"/>
    </resultMap>

    <select id="selectByLoginId" parameterType="String" resultMap="adminResultMap">
        SELECT LOGIN_ID, LOGIN_PWD, ADMIN_NM, ROLE_CD, USE_YN
        FROM ST_ADMIN_BASE
        WHERE LOGIN_ID = #{loginId}
    </select>

</mapper>
